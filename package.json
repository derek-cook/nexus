{
  "name": "bun-react-template",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --hot src/server/index.ts",
    "start": "NODE_ENV=production bun src/server/index.ts",
    "build": "bun run build.ts",
    "typecheck": "bunx tsc --noEmit -p tsconfig.app.json",
    "download-aircraft-db": "bun run scripts/download-aircraft-db.ts",
    "preprocess-aircraft-db": "bun run scripts/preprocess-aircraft-db.ts",
    "postinstall": "bun run copy-cesium",
    "copy-cesium": "rm -rf public/cesium && mkdir -p public/cesium && cp -r node_modules/cesium/Build/Cesium/Workers public/cesium/ && cp -r node_modules/cesium/Build/Cesium/Assets public/cesium/ && cp -r node_modules/cesium/Build/Cesium/ThirdParty public/cesium/ && cp -r node_modules/cesium/Build/Cesium/Widgets public/cesium/"
  },
  "dependencies": {
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.3",
    "bun-plugin-tailwind": "^0.1.2",
    "cesium": "^1.137.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.545.0",
    "react": "^19",
    "react-dom": "^19",
    "resium": "^1.19.3",
    "tailwind-merge": "^3.3.1"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.1.11",
    "tw-animate-css": "^1.4.0"
  }
}
